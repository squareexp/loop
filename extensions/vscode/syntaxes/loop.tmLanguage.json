{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loop",
  "patterns": [
    { "include": "#comments" },
    { "include": "#blocks" },
    { "include": "#goal_content" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#tool_declarations" },
    { "include": "#properties" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.loop",
          "match": "//.*$"
        },
        {
          "name": "comment.block.loop",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "entity.name.section.goal.loop",
          "match": "\\bGoal\\b"
        },
        {
          "name": "entity.name.section.memory.loop",
          "match": "\\bMemory\\b"
        },
        {
          "name": "entity.name.section.task.loop",
          "match": "\\bTask\\b"
        },
        {
          "name": "entity.name.section.discovery.loop",
          "match": "\\bDiscovery\\b"
        },
        {
          "name": "entity.name.section.planning.loop",
          "match": "\\bPlanning\\b"
        },
        {
          "name": "entity.name.section.execution.loop",
          "match": "\\bExecution\\b"
        },
        {
          "name": "entity.name.section.verification.loop",
          "match": "\\bVerification\\b"
        }
      ]
    },
    "goal_content": {
      "comment": "Goal [ ... ] — the text inside is an unquoted string",
      "begin": "(?<=\\bGoal\\s*)\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.section.goal.begin.loop" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.goal.end.loop" }
      },
      "name": "string.unquoted.goal.loop"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.field.loop",
          "match": "\\b(scan|find|steps|max_iterations|tools|strategy|checks|on_fail|max_retries)\\b(?=\\s*:)"
        },
        {
          "name": "keyword.other.on-fail.loop",
          "match": "\\b(retry|complete)\\b"
        },
        {
          "name": "constant.language.boolean.loop",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.loop",
          "match": "\\b(string|int|bool)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.loop",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.loop",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.integer.loop",
      "match": "\\b-?[0-9]+\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.loop",
          "match": "->"
        },
        {
          "name": "punctuation.separator.colon.loop",
          "match": ":"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.loop",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.loop",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.goal.begin.loop",
          "match": "\\["
        },
        {
          "name": "punctuation.section.goal.end.loop",
          "match": "\\]"
        },
        {
          "name": "punctuation.definition.group.loop",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.comma.loop",
          "match": ","
        }
      ]
    },
    "tool_declarations": {
      "patterns": [
        {
          "comment": "tool declaration: name(params) -> type",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.loop" }
          }
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": { "name": "variable.other.property.loop" }
          }
        }
      ]
    }
  },
  "scopeName": "source.loop"
}
