{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loop",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#state_variables"
    },
    {
      "include": "#properties"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.loop",
          "match": "//.*$"
        },
        {
          "name": "comment.block.loop",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.block.loop",
          "match": "\\b(task|state|tools|invariant|strategy|until|fallback)\\b"
        },
        {
          "name": "keyword.other.loop",
          "match": "\\b(tool)\\b"
        },
        {
          "name": "constant.language.boolean.loop",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.loop",
          "match": "\\b(string|int|bool)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.loop",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.loop",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.loop",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.loop",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.loop",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.arrow.loop",
          "match": "->"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.loop",
          "match": "\\{|\\}"
        },
        {
          "name": "punctuation.definition.group.loop",
          "match": "\\(|\\)"
        },
        {
          "name": "punctuation.separator.loop",
          "match": ",|:"
        }
      ]
    },
    "state_variables": {
      "patterns": [
        {
          "match": "\\b(state)\\b(?:\\.([a-zA-Z_][a-zA-Z0-9_]*))?",
          "captures": {
            "1": {
              "name": "variable.language.state.loop"
            },
            "2": {
              "name": "variable.other.member.loop"
            }
          }
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": {
              "name": "variable.other.property.loop"
            }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(tool)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.loop"
            },
            "2": {
              "name": "entity.name.function.declaration.loop"
            }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.loop"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.loop"
}
