{
  "Complete Loop File": {
    "prefix": ["loop", "lf"],
    "scope": "loop",
    "body": [
      "Goal [",
      "    ${1:Describe your goal in plain language. What does done look like?}",
      "]",
      "",
      "Memory {",
      "    project_path: \"${2:./}\"",
      "    notes: []",
      "}",
      "",
      "Task {",
      "    \"${3:First concrete task}\"",
      "    \"${4:Second concrete task}\"",
      "}",
      "",
      "Discovery {",
      "    scan: [\"${5:**/*}\"]",
      "    find: [",
      "        \"${6:What already exists?}\"",
      "        \"${7:What is missing?}\"",
      "    ]",
      "}",
      "",
      "Planning {",
      "    steps: [",
      "        \"${8:Run discovery and record findings}\"",
      "        \"${9:Implement the first task}\"",
      "        \"${10:Verify and complete}\"",
      "    ]",
      "    max_iterations: ${11:5}",
      "}",
      "",
      "Execution {",
      "    tools: [",
      "        read_file(path: string) -> string",
      "        write_file(path: string, content: string) -> bool",
      "        run_command(cmd: string) -> string",
      "        list_dir(path: string) -> string",
      "    ]",
      "    strategy: \"${12:Execute steps in order. Read before writing. Verify after each step.}\"",
      "}",
      "",
      "Verification {",
      "    checks: [",
      "        \"${13:First success condition}\"",
      "        \"${14:Second success condition}\"",
      "    ]",
      "    on_fail: retry",
      "    max_retries: ${15:3}",
      "}"
    ],
    "description": "Create a complete Loop Engineering file with all seven blocks"
  },
  "Goal Block": {
    "prefix": ["goal", "go", "Go"],
    "scope": "loop",
    "body": [
      "Goal [",
      "    ${1:Describe what you want to achieve}",
      "]"
    ],
    "description": "Goal [ ] — plain language goal using square brackets"
  },
  "Memory Block": {
    "prefix": ["memory", "me", "Me"],
    "scope": "loop",
    "body": [
      "Memory {",
      "    ${1:key}: \"${2:value}\"",
      "}"
    ],
    "description": "Memory { } — persistent agent state across sessions"
  },
  "Task Block": {
    "prefix": ["task", "ta", "Ta"],
    "scope": "loop",
    "body": [
      "Task {",
      "    \"${1:First concrete task}\"",
      "    \"${2:Second concrete task}\"",
      "    \"${3:Third concrete task}\"",
      "}"
    ],
    "description": "Task { } — specific implementation items"
  },
  "Discovery Block": {
    "prefix": ["discovery", "di", "Di"],
    "scope": "loop",
    "body": [
      "Discovery {",
      "    scan: [\"${1:**/*}\"]",
      "    find: [",
      "        \"${2:What already exists?}\"",
      "        \"${3:What is missing?}\"",
      "    ]",
      "}"
    ],
    "description": "Discovery { } — scan files and answer questions before coding"
  },
  "Planning Block": {
    "prefix": ["planning", "pl", "Pl"],
    "scope": "loop",
    "body": [
      "Planning {",
      "    steps: [",
      "        \"${1:First step}\"",
      "        \"${2:Second step}\"",
      "        \"${3:Third step}\"",
      "    ]",
      "    max_iterations: ${4:5}",
      "}"
    ],
    "description": "Planning { } — ordered steps with an iteration budget"
  },
  "Execution Block": {
    "prefix": ["execution", "ex", "Ex"],
    "scope": "loop",
    "body": [
      "Execution {",
      "    tools: [",
      "        read_file(path: string) -> string",
      "        write_file(path: string, content: string) -> bool",
      "        run_command(cmd: string) -> string",
      "        ${1:list_dir(path: string) -> string}",
      "    ]",
      "    strategy: \"${2:Execute steps in order. Read before writing.}\"",
      "}"
    ],
    "description": "Execution { } — available tools and execution strategy"
  },
  "Verification Block": {
    "prefix": ["verification", "ve", "Ve"],
    "scope": "loop",
    "body": [
      "Verification {",
      "    checks: [",
      "        \"${1:First success condition}\"",
      "        \"${2:Second success condition}\"",
      "    ]",
      "    on_fail: ${3|retry,complete|}",
      "    max_retries: ${4:3}",
      "}"
    ],
    "description": "Verification { } — success criteria with retry behavior"
  },
  "Tool Declaration": {
    "prefix": ["tool", "to"],
    "scope": "loop",
    "body": "${1:tool_name}(${2:param}: ${3|string,int,bool|}) -> ${4|string,bool,int|}",
    "description": "Declare a tool: name(param: type) -> return_type"
  },
  "Memory Field": {
    "prefix": "field",
    "scope": "loop",
    "body": "${1:key}: \"${2:value}\"",
    "description": "Memory field: key: \"value\""
  },
  "Task Item": {
    "prefix": "item",
    "scope": "loop",
    "body": "\"${1:Task description}\"",
    "description": "A single Task item string"
  }
}
