{
  "name": "loopagent",
  "displayName": "LoopAgent",
  "description": "Support Extension for loop agentic language",
  "version": "0.1.0",
  "publisher": "squareexp",
  "icon": "brain.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "loop",
        "aliases": [
          "Loop",
          "loop"
        ],
        "extensions": [
          ".loop"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./brain.png",
          "dark": "./brain.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "loop",
        "scopeName": "source.loop",
        "path": "./syntaxes/loop.tmLanguage.json"
      }
    ]
  }
}
