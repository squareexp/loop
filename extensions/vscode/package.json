{
  "name": "loopagent",
  "displayName": "Loop Engineering Language",
  "description": "Language support for .loop files — structured AI agent task files with Goal, Memory, Discovery, Planning, Execution, and Verification blocks.",
  "version": "0.2.0",
  "publisher": "squareexp",
  "icon": "brain.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "loop",
        "aliases": ["Loop", "loop"],
        "extensions": [".loop"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./brain.png",
          "dark": "./brain.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "loop",
        "scopeName": "source.loop",
        "path": "./syntaxes/loop.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "loop",
        "path": "./snippets/loop.json"
      }
    ]
  }
}
