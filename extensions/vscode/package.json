{
  "name": "loopagent",
  "displayName": "Loop Engineering Language",
  "description": "Syntax highlighting, completions, and snippets for .loop files — structured AI agent task specifications.",
  "version": "0.2.0",
  "publisher": "squareexp",
  "icon": "brain.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/squareexp/loop"
  },
  "keywords": ["loop", "ai", "agent", "dsl", "task", "engineering"],
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "loop",
        "aliases": ["Loop", "loop"],
        "extensions": [".loop"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./brain.png",
          "dark": "./brain.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "loop",
        "scopeName": "source.loop",
        "path": "./syntaxes/loop.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "loop",
        "path": "./snippets/loop.json"
      }
    ]
  }
}
