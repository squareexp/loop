// main.loop — example Loop Engineering file
// Run: loop check main.loop
//      loop scaffold main.loop
//      loop run main.loop --provider claude

Goal [
    Develop and integrate a Rust-backed Language Server Protocol (LSP) for the
    Loop language — providing real-time syntax completions, compiler errors, and
    diagnostics inside VS Code when editing .loop files.
]

Memory {
    project_path: "./loop"
    lsp_connected: false
    diagnostics_sent: false
    known_tech: ["Rust", "pest", "tower-lsp", "VS Code Extension API"]
}

Discovery {
    scan: ["src/**/*.rs", "src/parser/loop.pest", "extensions/vscode/**/*.json"]
    find: [
        "Is tower-lsp already in Cargo.toml?"
        "What grammar rules are defined in loop.pest?"
        "Does the VS Code extension have a server activation entry point?"
    ]
}

Planning {
    steps: [
        "Add tower-lsp dependency to Cargo.toml"
        "Create src/lsp/mod.rs with LoopLspServer struct"
        "Implement textDocument/didOpen and textDocument/didChange handlers"
        "Wire parse_loop_file diagnostics into publishDiagnostics notifications"
        "Add completions for Goal/Memory/Discovery/Planning/Execution/Verification keywords"
        "Update VS Code extension to launch the LSP server binary"
        "Write integration test: open broken .loop file, verify diagnostic appears"
    ]
    max_iterations: 10
}

Execution {
    tools: [
        read_file(path: string) -> string
        write_file(path: string, content: string) -> bool
        run_command(cmd: string) -> string
        list_dir(path: string) -> string
    ]
    strategy: "Execute planning steps sequentially. After each file change run
               'cargo check' to confirm the build stays clean. Track progress
               in .loop/state.json."
}

Verification {
    checks: [
        "cargo build succeeds with no errors"
        "loop check main.loop reports all checks passed"
        "Opening a broken .loop file in VS Code shows a red underline error"
        "Typing 'Goal' in a new .loop file triggers autocomplete"
    ]
    on_fail: retry
    max_retries: 5
}
