// test.loop — minimal example showing all seven blocks

Goal [
    Write a hello-world function to src/hello.rs and confirm it compiles.
]

Memory {
    project_path: "."
    language: "Rust"
}

Task {
    "Create src/hello.rs with a hello() function"
    "Add hello to src/main.rs"
    "Confirm cargo build passes"
}

Discovery {
    scan: ["src/**/*.rs", "Cargo.toml"]
    find: [
        "Does src/hello.rs already exist?"
        "Is hello() already declared somewhere?"
    ]
}

Planning {
    steps: [
        "Read src/main.rs to understand the current structure"
        "Write src/hello.rs with a hello() function"
        "Update src/main.rs to call hello()"
        "Run cargo build to confirm it compiles"
    ]
    max_iterations: 4
}

Execution {
    tools: [
        read_file(path: string) -> string
        write_file(path: string, content: string) -> bool
        run_command(cmd: string) -> string
    ]
    strategy: "Read before writing. Run cargo build after each file change."
}

Verification {
    checks: [
        "cargo build"
    ]
    on_fail: retry
    max_retries: 2
}
